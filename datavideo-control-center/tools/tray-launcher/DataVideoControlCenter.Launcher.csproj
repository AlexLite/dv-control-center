<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>DataVideoControlCenter.Launcher</RootNamespace>
    <AssemblyName>DataVideoControlCenter.Launcher</AssemblyName>
    <ApplicationIcon>assets\datavideo-favicon.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="assets\datavideo-favicon.ico" />
    <EmbeddedResource Include="assets\datavideo-favicon.png" />
  </ItemGroup>
</Project>
